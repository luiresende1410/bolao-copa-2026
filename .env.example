# === Application ===
NODE_ENV=development
PORT_API=3000

# === PostgreSQL (RDS) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_panel
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# === Redis (ElastiCache) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# === JWT ===
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ISSUER=whatsapp-panel
JWT_EXPIRATION=8h

# === Bcrypt ===
BCRYPT_ROUNDS=10

# === Logging ===
LOG_LEVEL=info